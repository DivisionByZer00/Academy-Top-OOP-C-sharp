using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Reflection.Metadata;
using System.Threading.Tasks;
using System.Xml;
using Newtonsoft.Json;
using Formatting = Newtonsoft.Json.Formatting;


class Program
{
    public class Bidder
    {
        public string Name { get; }

        public Bidder(string name)
        {
            Name = name;
        }


        public void OnPriceChanged(string lotName, string bidderName, decimal newPrice)
        {

            if (bidderName == Name)
                return;

            Console.WriteLine($"  [{Name}]: Новая ставка на '{lotName}' - {newPrice} (от {bidderName}).");
        }
    }

    public delegate void PriceChangedHandler(string lotName, string bidderName, decimal newPrice);

    public class AuctionLot
    {
        public string Name { get; }
        public decimal CurrentPrice { get; private set; }


        public event PriceChangedHandler PriceChanged;

        public AuctionLot(string name, decimal startPrice)
        {
            Name = name;
            CurrentPrice = startPrice;
        }

        public void PlaceBid(Bidder bidder, decimal newPrice)
        {

            Console.WriteLine($"{bidder.Name} делает ставку: {newPrice}");


            if (newPrice <= CurrentPrice)
            {
                Console.WriteLine($"  Ставка не принята. Сумма должна быть выше {CurrentPrice}.");
                return;
            }

            CurrentPrice = newPrice;

            

            if (PriceChanged != null)
            {
                PriceChanged(Name, bidder.Name, newPrice);
            }
        }
    }

    static void Main(string[] args)
    {
        AuctionLot lot = new AuctionLot("Старинная ваза", 1000m);

        Console.WriteLine($"--- Аукцион начинается! Лот: '{lot.Name}'. Начальная цена: {lot.CurrentPrice} ---\n");


        Bidder ivan = new Bidder("Иван");
        Bidder petr = new Bidder("Петр");
        Bidder anna = new Bidder("Анна");


        lot.PriceChanged += ivan.OnPriceChanged;
        Console.WriteLine("Участник 'Иван' подписался на лот.");

        lot.PriceChanged += petr.OnPriceChanged;
        Console.WriteLine("Участник 'Петр' подписался на лот.");

        lot.PriceChanged += anna.OnPriceChanged;
        Console.WriteLine("Участник 'Анна' подписался на лот.");

        Console.WriteLine();


        lot.PlaceBid(ivan, 1200m);
        Console.WriteLine();

        lot.PlaceBid(anna, 1500m);
        Console.WriteLine();

        lot.PlaceBid(petr, 1300m);
        Console.WriteLine();
    }


}
