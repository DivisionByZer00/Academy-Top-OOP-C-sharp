using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Reflection.Metadata;
using System.Threading.Tasks;
using System.Xml;
using Newtonsoft.Json;
using Formatting = Newtonsoft.Json.Formatting;


class Program
{
    public class Product
    {
        public string Name { get; set; }
        public int Price { get; set; }
    }

    public interface IExportStrategy
    {
        void Export(IEnumerable<Product> data);
    }


    public class CsvExportStrategy : IExportStrategy
    {
        public void Export(IEnumerable<Product> data)
        {
            Console.WriteLine("Экспортирую данные...");
            Console.WriteLine("Name,Price");

            foreach (var product in data)
            {
                Console.WriteLine($"{product.Name},{product.Price}");
            }
        }
    }

    public class JsonExportStrategy : IExportStrategy
    {
        public void Export(IEnumerable<Product> data)
        {
            Console.WriteLine("Экспортирую данные...");
            Console.WriteLine("[");

            bool first = true;

            foreach (var product in data)
            {
                if (!first)
                    Console.WriteLine(",");

                Console.WriteLine("  {");
                Console.WriteLine($"    \"Name\": \"{product.Name}\",");
                Console.WriteLine($"    \"Price\": {product.Price}");
                Console.WriteLine("  }");

                first = false;
            }

            Console.WriteLine("]");
        }
    }

    public class DataExporter
    {
        private IExportStrategy strategy;

        public void SetStrategy(IExportStrategy newStrategy)
        {
            strategy = newStrategy;
        }

        public void ExportData(IEnumerable<Product> data)
        {
            if (strategy == null)
            {
                return;
            }

            strategy.Export(data);
        }
    }



    static void Main(string[] args)
    {
        {
            Console.WriteLine("--- Универсальный экспортер данных ---\n");

            List<Product> products = new List<Product>
        {
            new Product { Name = "Ноутбук", Price = 1200 },
            new Product { Name = "Мышь", Price = 25 }
        };

            Console.WriteLine("Данные для экспорта:");
            foreach (var p in products)
            {
                Console.WriteLine($"- Продукт: {p.Name}, Цена: {p.Price}");
            }

            Console.WriteLine("\nЭкспорт в формате CSV:");
            DataExporter exporter = new DataExporter();
            exporter.SetStrategy(new CsvExportStrategy());
            exporter.ExportData(products);

            Console.WriteLine("\n--- Меняем стратегию на JSON ---\n");

            Console.WriteLine("Экспорт в формате JSON:");
            exporter.SetStrategy(new JsonExportStrategy());
            exporter.ExportData(products);
        }
    }


}
